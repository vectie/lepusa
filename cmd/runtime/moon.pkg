import {
  "moonbitlang/async",
  "moonbitlang/async/fs",
  "moonbitlang/x/sys",
  "vectie/lepusa",
  "vectie/lepusa/runtime" @runtime_core,
  "vectie/lepusa/runtime/bundled",
  "vectie/lepusa/runtime/linux",
  "vectie/lepusa/runtime/macos",
  "vectie/lepusa/runtime/windows",
}

supported_targets = "+native"

options(
  "bin-name": "lepusa-runtime",
  "bin-target": "native",
  "is-main": true,
  targets: { "main.mbt": [ "native" ] },
)
